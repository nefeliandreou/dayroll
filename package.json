{
  "name": "dayroll",
  "version": "0.1.0",
  "description": "A daily todo list that carries unfinished tasks to the next day",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "dev:server": "node --watch --env-file=.env server/index.js",
    "dev:all": "npm run dev:server & npm run dev",
    "build": "vite build",
    "start": "node server/index.js",
    "test": "vitest --run"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "connect-pg-simple": "^10.0.0",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "fast-check": "^3.19.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^1.6.0"
  }
}
